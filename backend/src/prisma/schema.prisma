generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id         Int        @id @default(autoincrement())
  nome       String
  email      String     @unique
  telefone   String?
  cpf        String     @unique
  senha      String
  isAdmin    Boolean    @default(false)
  fotoPerfil String?
  bio        String?    @db.Text
  createdAt  DateTime   @default(now())
  resenhas   Resenha[]
  favoritos  Favorito[]
  curtidas   CurtidaResenha[]
  comentarios Comentario[]
}

model Livro {
  id          Int        @id @default(autoincrement())
  titulo      String
  autor       String
  ano         Int
  editora     String
  paginas     Int
  isbn        String?    @unique
  categoria   String?
  sinopse     String?    @db.Text
  idioma      String     @default("Português")
  edicao      String?
  fotoCapa    String
  galeria     String[]
  ativo       Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  resenhas    Resenha[]
  favoritos   Favorito[]
}

model Resenha {
  id              Int      @id @default(autoincrement())
  livroId         Int
  usuarioId       Int
  titulo          String
  textoResumo     String   @db.Text
  textoCompleto   String   @db.Text
  avaliacao       Float    // 0.0 a 5.0
  trechosMarcantes String[] // Array de citações
  curtidas        Int      @default(0)
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  livro           Livro    @relation(fields: [livroId], references: [id], onDelete: Cascade)
  usuario         Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  curtidasResenha CurtidaResenha[]
  comentarios     Comentario[]
  
  @@index([livroId])
  @@index([usuarioId])
}

model Comentario {
  id         Int      @id @default(autoincrement())
  resenhaId  Int
  usuarioId  Int
  texto      String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  resenha    Resenha  @relation(fields: [resenhaId], references: [id], onDelete: Cascade)
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  
  @@index([resenhaId])
  @@index([usuarioId])
}

model Favorito {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  livroId    Int
  createdAt  DateTime @default(now())
  
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  livro      Livro    @relation(fields: [livroId], references: [id], onDelete: Cascade)
  
  @@unique([usuarioId, livroId])
  @@index([usuarioId])
  @@index([livroId])
}

model CurtidaResenha {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  resenhaId  Int
  createdAt  DateTime @default(now())
  
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  resenha    Resenha  @relation(fields: [resenhaId], references: [id], onDelete: Cascade)
  
  @@unique([usuarioId, resenhaId])
  @@index([usuarioId])
  @@index([resenhaId])
}
