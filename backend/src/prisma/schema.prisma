generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  telefone  String?
  cpf       String   @unique
  senha     String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Livro {
  id          Int      @id @default(autoincrement())
  titulo      String
  autor       String
  ano         Int
  editora     String
  paginas     Int
  isbn        String?  @unique
  categoria   String?
  sinopse     String?  @db.Text
  idioma      String   @default("Português")
  edicao      String?
  fotoCapa    String
  galeria     String[]
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
