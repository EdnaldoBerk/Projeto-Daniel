generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id         Int        @id @default(autoincrement())
  nome       String
  email      String     @unique
  telefone   String?
  cpf        String     @unique
  senha      String
  isAdmin    Boolean    @default(false)
  fotoPerfil String?
  bio        String?    @db.Text
  createdAt  DateTime   @default(now())
  resenhas   Resenha[]
  favoritos  Favorito[]
  curtidas   CurtidaResenha[]
  avaliacoesResenha AvaliacaoResenha[]
  comentarios Comentario[]
  denuncias  DenunciaComentario[]
  leituras   LeituraUsuario[]
}

model Livro {
  id          Int        @id @default(autoincrement())
  titulo      String
  autor       String
  ano         Int
  editora     String
  paginas     Int
  isbn        String?    @unique
  categoria   String?
  sinopse     String?    @db.Text
  idioma      String     @default("Português")
  edicao      String?
  fotoCapa    String
  galeria     String[]
  ativo       Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  resenhas    Resenha[]
  favoritos   Favorito[]
  leituras    LeituraUsuario[]
}

model Resenha {
  id              Int      @id @default(autoincrement())
  livroId         Int
  usuarioId       Int
  titulo          String
  textoResumo     String   @db.Text
  textoCompleto   String   @db.Text
  avaliacao       Float    // 0.0 a 5.0
  trechosMarcantes String[] // Array de citações
  curtidas        Int      @default(0)
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  livro           Livro    @relation(fields: [livroId], references: [id], onDelete: Cascade)
  usuario         Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  curtidasResenha CurtidaResenha[]
  avaliacoes      AvaliacaoResenha[]
  comentarios     Comentario[]
  
  @@index([livroId])
  @@index([usuarioId])
}

model AvaliacaoResenha {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  resenhaId  Int
  nota       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  resenha    Resenha  @relation(fields: [resenhaId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, resenhaId])
  @@index([usuarioId])
  @@index([resenhaId])
}

model Comentario {
  id         Int      @id @default(autoincrement())
  resenhaId  Int
  usuarioId  Int
  parentId   Int?
  texto      String   @db.Text
  nota       Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  resenha    Resenha  @relation(fields: [resenhaId], references: [id], onDelete: Cascade)
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  parent     Comentario? @relation("ComentarioReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comentario[] @relation("ComentarioReplies")
  denuncias  DenunciaComentario[]
  
  @@index([resenhaId])
  @@index([usuarioId])
  @@index([parentId])
}

model DenunciaComentario {
  id          Int      @id @default(autoincrement())
  comentarioId Int
  usuarioId   Int
  motivo      String   // 'spam', 'ofensivo', 'inapropriado', 'conteudo_falso', 'outro'
  descricao   String?  @db.Text
  status      String   @default("pendente") // 'pendente', 'analisado', 'rejeitado'
  createdAt   DateTime @default(now())
  
  comentario  Comentario @relation(fields: [comentarioId], references: [id], onDelete: Cascade)
  usuario     Usuario    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  
  @@unique([comentarioId, usuarioId])
  @@index([comentarioId])
  @@index([usuarioId])
}

model Favorito {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  livroId    Int
  createdAt  DateTime @default(now())
  
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  livro      Livro    @relation(fields: [livroId], references: [id], onDelete: Cascade)
  
  @@unique([usuarioId, livroId])
  @@index([usuarioId])
  @@index([livroId])
}

model LeituraUsuario {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  livroId    Int
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  livro      Livro    @relation(fields: [livroId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, livroId])
  @@index([usuarioId])
  @@index([livroId])
  @@index([status])
}

model CurtidaResenha {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  resenhaId  Int
  createdAt  DateTime @default(now())
  
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  resenha    Resenha  @relation(fields: [resenhaId], references: [id], onDelete: Cascade)
  
  @@unique([usuarioId, resenhaId])
  @@index([usuarioId])
  @@index([resenhaId])
}
